{
  "name": "stdas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm --dir apps/web build",
    "typecheck": "pnpm --dir apps/web typecheck",
    "lint": "pnpm --dir apps/web lint",
    "test": "pnpm --dir apps/web test",
    "web:dev": "pnpm --dir apps/web dev",
    "web:build": "pnpm --dir apps/web build",
    "web:typecheck": "pnpm --dir apps/web typecheck",
    "web:lint": "pnpm --dir apps/web lint",
    "web:test": "pnpm --dir apps/web test",
    "gateway:start": "cargo loco start",
    "gateway:routes": "cargo loco routes"
  }
}
